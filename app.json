{
  "expo": {
    "name": "Gita-Ai Samvad",
    "slug": "gita-ai-samvad",
    "owner": "levelupcoders-organization",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.levelupcodersorganization.gitaaisamvad",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3df13bdc-2ce2-4725-8e5f-0bbca9629b07"
      }
    },
    "plugins": [
      "@react-native-voice/voice",
      [
        "expo-build-properties",
        {
          "android": {}
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3df13bdc-2ce2-4725-8e5f-0bbca9629b07"
    }
  }
}
